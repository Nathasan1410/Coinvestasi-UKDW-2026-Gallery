{
  "framework": "vite",
  "buildCommand": "cd client && npm run build",
  "installCommand": "cd api && npm install",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/files/:folder", "destination": "api/files/[folder].ts" },
    { "source": "/(.*)", "destination": "/client/dist/index.html" }
  ],
  "functions": {
    "api/files/[folder].ts": {
      "maxDuration": 10
    }
  }
}